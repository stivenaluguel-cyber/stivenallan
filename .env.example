# ── Site ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://stivenallan.com.br

# ── Mensuração (client, públicas) ──────────────────────────────────────
# IDs têm fallback hardcoded em src/lib/tracking-config.ts pra produção não
# quebrar sem env — mas o certo é declará-las na Vercel.
NEXT_PUBLIC_GA4_ID=G-5TWF0JTG8H
NEXT_PUBLIC_META_PIXEL_ID=364836344657445
# Google Ads (só quando a conta existir; sem elas, nada do Ads carrega/dispara)
NEXT_PUBLIC_GADS_ID=
NEXT_PUBLIC_GADS_CONVERSION=

# ── Meta Conversions API (server, secretas) ────────────────────────────
# Gerenciador de Eventos → pixel → Configurações → Gerar token de acesso
META_CAPI_TOKEN=
# Opcional, SÓ durante validação: código da aba "Testar eventos" do
# Gerenciador de Eventos (ex.: TEST12345). Remover depois de validar.
META_TEST_EVENT_CODE=

# ── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── E-mail (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="Stiven Allan <contato@stivenallan.com.br>"

# ── Segurança / tokens ─────────────────────────────────────────────────
UNSUBSCRIBE_SECRET=
JWT_SECRET=

# ── Sentry (DSN não é segredo) ─────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
